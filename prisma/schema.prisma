generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Game {
  id         String     @id @default(uuid())
  answer     String
  imageUrl   String
  hints      Json
  difficulty Int
  createdAt  DateTime   @default(now())

  dailyGames DailyGame[]
  guesses    UserGuess[]
}

model DailyGame {
  id     String   @id @default(uuid())
  gameId String
  date   DateTime

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([date])
  @@index([gameId])
}

model UserGuess {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  guess     String
  isCorrect Boolean
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameId])
}

